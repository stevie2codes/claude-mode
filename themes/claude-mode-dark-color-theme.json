      "name": "TOML Key",
      "scope": [
        "keyword.key.toml",
        "support.type.property-name.toml"
      ],
      "settings": {
        "foreground": "#6a9bcc"
      }
    },
    {
      "name": "Inserted (diff)",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#8fa874"
      }
    },
    {
      "name": "Deleted (diff)",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#c44d3e"
      }
    },
    {
      "name": "Changed (diff)",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#6a9bcc"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#c44d3e",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#6b6961",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticTokenColors": {
    "variable.readonly": "#d4a05a",
    "variable.defaultLibrary": "#c9956b",
    "property.readonly": "#d4a05a",
    "function.declaration": {
      "foreground": "#6a9bcc",
      "fontStyle": "bold"
    },
    "function.defaultLibrary": "#6a9bcc",
    "parameter": {
      "foreground": "#b0aea5",
      "fontStyle": "italic"
    },
    "type": "#c9956b",
    "type.defaultLibrary": "#c9956b",
    "interface": {
      "foreground": "#c9956b",
      "fontStyle": "italic"
    },
    "enum": "#c9956b",
    "enumMember": "#d4a05a",
    "namespace": "#c9956b",
    "class": "#c9956b",
    "class.defaultLibrary": "#c9956b",
    "decorator": {
      "foreground": "#c9956b",
      "fontStyle": "italic"
    }
  }
}
