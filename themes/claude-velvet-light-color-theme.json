  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#a09d93", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "keyword.other", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#6b3a69" }
    },
    {
      "name": "Keyword Operator",
      "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.logical", "keyword.operator.comparison"],
      "settings": { "foreground": "#5a3558" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#788c5d" }
    },
    {
      "name": "String Escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#8b6e5a" }
    },
    {
      "name": "Template String Interpolation",
      "scope": ["punctuation.definition.template-expression.begin", "punctuation.definition.template-expression.end", "punctuation.section.embedded"],
      "settings": { "foreground": "#6b3a69" }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": { "foreground": "#5a82a6" }
    },
    {
      "name": "Function Parameters",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#6b6961", "fontStyle": "italic" }
    },
    {
      "name": "Types and Classes",
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class"],
      "settings": { "foreground": "#9b6a6e" }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#9b6a6e", "fontStyle": "italic" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other", "variable.other.readwrite"],
      "settings": { "foreground": "#3d3929" }
    },
    {
      "name": "Variable Property",
      "scope": ["variable.other.property", "variable.other.object.property", "support.variable.property"],
      "settings": { "foreground": "#4d4639" }
    },
    {
      "name": "Constants and Numbers",
      "scope": ["constant", "constant.numeric", "constant.language", "support.constant", "constant.other"],
      "settings": { "foreground": "#a67235" }
    },
    {
      "name": "Operators and Punctuation",
      "scope": ["punctuation", "punctuation.definition.block", "punctuation.definition.parameters", "punctuation.separator", "punctuation.terminator", "meta.brace"],
      "settings": { "foreground": "#6b6961" }
    },
    {
      "name": "HTML Tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#6b3a69" }
    },
    {
      "name": "HTML/XML Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#6a9bcc", "fontStyle": "italic" }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css", "support.type.vendored.property-name.css", "meta.property-name.css"],
      "settings": { "foreground": "#5a82a6" }
    },
    {
      "name": "CSS Values",
      "scope": ["support.constant.property-value.css", "constant.other.color.rgb-value.hex.css", "support.constant.color.css"],
      "settings": { "foreground": "#a67235" }
    },
    {
      "name": "CSS Selectors",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css", "entity.name.tag.css"],
      "settings": { "foreground": "#9b6a6e" }
    },
    {
      "name": "CSS Pseudo",
      "scope": ["entity.other.attribute-name.pseudo-class.css", "entity.other.attribute-name.pseudo-element.css"],
      "settings": { "foreground": "#788c5d" }
    },
    {
      "name": "Decorators / Annotations",
      "scope": ["meta.decorator", "punctuation.decorator", "meta.decorator entity.name.function"],
      "settings": { "foreground": "#9b6a6e", "fontStyle": "italic" }
    },
    {
      "name": "JSON Keys",
      "scope": ["support.type.property-name.json", "string.json support.type.property-name.json"],
      "settings": { "foreground": "#5a82a6" }
    },
    {
      "name": "JSON Values String",
      "scope": ["meta.structure.dictionary.value.json string.quoted.double.json"],
      "settings": { "foreground": "#788c5d" }
    },
    {
      "name": "Markdown Headings",
      "scope": ["markup.heading", "entity.name.section.markdown", "markup.heading.setext"],
      "settings": { "foreground": "#6b3a69", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#2c2a25", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#2c2a25", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Link",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#5a82a6" }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block", "markup.raw.block"],
      "settings": { "foreground": "#9b6a6e" }
    },
    {
      "name": "Markdown List",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#7a4a78" }
    },
    {
      "name": "Markdown Quote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#6b6961", "fontStyle": "italic" }
    },
    {
      "name": "This / Self",
      "scope": ["variable.language.this", "variable.language.self", "variable.language.special.self"],
      "settings": { "foreground": "#7a4a78", "fontStyle": "italic" }
    },
    {
      "name": "Import / Export",
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from", "keyword.control.as"],
      "settings": { "foreground": "#6b3a69" }
    },
    {
      "name": "Namespace",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": { "foreground": "#9b6a6e" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp", "constant.other.character-class.regexp", "keyword.operator.quantifier.regexp"],
      "settings": { "foreground": "#8b6e5a" }
    },
    {
      "name": "YAML Key",
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#5a82a6" }
    },
    {
      "name": "TOML Key",
      "scope": ["keyword.key.toml", "support.type.property-name.toml"],
      "settings": { "foreground": "#5a82a6" }
    },
    {
      "name": "Inserted (diff)",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#788c5d" }
    },
    {
      "name": "Deleted (diff)",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#c44d3e" }
    },
    {
      "name": "Changed (diff)",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#6a9bcc" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#c44d3e", "fontStyle": "strikethrough" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#a09d93", "fontStyle": "strikethrough" }
    }
  ],
  "semanticTokenColors": {
    "variable.readonly": "#a67235",
    "variable.defaultLibrary": "#9b6a6e",
    "property.readonly": "#a67235",
    "function.declaration": { "foreground": "#5a82a6", "fontStyle": "bold" },
    "function.defaultLibrary": "#5a82a6",
    "parameter": { "foreground": "#6b6961", "fontStyle": "italic" },
